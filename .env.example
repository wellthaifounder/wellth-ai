# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# ── Supabase Edge Functions ───────────────────────────────────────────────────
# Injected automatically by Supabase at runtime — do NOT set these manually:
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY

# ── Stripe ────────────────────────────────────────────────────────────────────
# Publishable key (safe to expose in frontend) — Vercel env var
VITE_STRIPE_PUBLISHABLE_KEY="pk_live_..."
# Secret key — Supabase Edge Function secret only, never in frontend
STRIPE_SECRET_KEY="sk_live_..."

# ── Plaid ─────────────────────────────────────────────────────────────────────
# From Plaid dashboard → Team Settings → Keys
PLAID_CLIENT_ID="your-plaid-client-id"
PLAID_SECRET="your-plaid-secret"
PLAID_ENV="sandbox"  # sandbox | development | production
# 32-byte (256-bit) random key used to encrypt Plaid access tokens at rest
# Generate with: openssl rand -hex 32
PLAID_ENCRYPTION_KEY="your-64-char-hex-encryption-key"

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."

# ── CORS ─────────────────────────────────────────────────────────────────────
# Restrict edge function responses to this origin (your production domain)
ALLOWED_ORIGIN="https://wellth-ai.app"

# ── Lovable Integration ───────────────────────────────────────────────────────
LOVABLE_API_KEY="your-lovable-api-key"

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Wave 3 (2026-05) onboarding consolidation experiment. Both default off in
# production; flip to "true" to run the experiment, monitor telemetry for
# ≥7 days, then either widen or roll back. See docs/ux-review-2026-05.md §3.

# Auto-dismiss the OnboardingWizard carousel for users who picked
# userIntent === 'billing' (HSA / both still see it).
VITE_FF_AUTO_DISMISS_ONBOARDING_FOR_BILLING="false"

# Show the Get-Started progress ribbon only on /dashboard (instead of every
# authenticated page).
VITE_FF_SCOPE_GET_STARTED_TO_DASHBOARD="false"
